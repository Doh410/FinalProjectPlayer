<%- include('partials/header', { title: 'Cut Player', page: 'cut' }) %>

<main>

  <section class="hero hero-sm">
    <div class="hero-content">
      <h2>Cut a Player</h2>
      <p>Remove a player from your lineup to rebuild your roster.</p>
    </div>
  </section>

  <section class="cut-section">

    <% if (message) { %>
    <div class="alert alert-success">✅ <%= message %></div>
    <% } %>
    <% if (error) { %>
    <div class="alert alert-error">❌ <%= error %></div>
    <% } %>

    <div class="cut-form-box">
      <h3>Search by Name</h3>
      <p>Type a player's name to remove them from your lineup.</p>
      <form action="/cut" method="POST" class="search-form">
        <input
          type="text"
          name="playerName"
          placeholder="e.g. LeBron James"
          required
        />
        <button type="submit" class="btn btn-danger">✂️ Cut Player</button>
      </form>
    </div>

    <% if (players.length > 0) { %>
    <div class="cut-roster">
      <h3>Current Roster — click to cut</h3>
      <div class="player-cards">
        <% players.forEach(p => { %>
        <div class="card">
          <div class="card-badge"><%= p.position %></div>
          <h3><%= p.firstName %> <%= p.lastName %></h3>
          <p class="team-name"><%= p.teamName %></p>
          <p class="meta">#<%= p.jerseyNumber %> &bull; <%= p.teamAbbr %></p>

          <form action="/cut" method="POST">
            <input type="hidden" name="playerId" value="<%= p._id %>">
            <button type="submit" class="btn btn-danger btn-sm"
              onclick="return confirm('Are you sure you want to cut <%= p.firstName %> <%= p.lastName %>?')">
              ✂️ Cut
            </button>
          </form>
        </div>
        <% }) %>
      </div>
    </div>
    <% } else { %>
    <div class="empty-state">
      <div class="empty-icon">✂️</div>
      <h3>No players to cut</h3>
      <p>Your lineup is empty. <a href="/search">Search for players</a> to add some.</p>
    </div>
    <% } %>

  </section>

</main>

<%- include('partials/footer') %>
